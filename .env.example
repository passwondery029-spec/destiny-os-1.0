ARK_API_KEY=
ARK_ENDPOINT_ID=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ==========================================
# 外部命理 Agent 配置 (可选)
# 如果你想使用自己搭建的专属 Agent (如 Coze, Dify) 来生成深度报告，请配置以下变量。
# 如果配置了此项，系统将不再使用内置大模型生成报告，而是将请求转发给该 URL。
# ==========================================
# 你的专属 Agent Webhook API 地址
EXTERNAL_REPORT_AGENT_URL=
# 你的专属 Agent API Key (如果需要)
EXTERNAL_REPORT_AGENT_KEY=
